# Copy this file to .env and set your preferred provider.

# Optional direct key (highest priority)
ANTAHKARANA_LLM_API_KEY=

# OpenAI-compatible bridge settings
ANTAHKARANA_LLM_ENABLED=true
ANTAHKARANA_LLM_PROVIDER=openai_compatible
ANTAHKARANA_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
ANTAHKARANA_LLM_MODEL=gpt-4o-mini
ANTAHKARANA_LLM_API_KEY_ENV=OPENAI_API_KEY

# Set the key variable referenced by ANTAHKARANA_LLM_API_KEY_ENV
OPENAI_API_KEY=your_api_key_here

# Optional provider-specific key variables
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
